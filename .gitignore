# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
# Per-package build outputs after the D.4 workspace restructure
packages/*/build/
# Library-package lockfiles aren't meant to be checked in (consumers resolve)
packages/core/pubspec.lock
packages/design/pubspec.lock

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Sensitive temporary scripts
test_api_key.dart
register_slave_script.dart
api.json

# Local credentials — never commit. Real values live here; secrets.example.json
# is the committed template for new contributors.
/secrets.json
